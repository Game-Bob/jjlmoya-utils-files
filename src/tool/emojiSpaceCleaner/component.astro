---
import type { KnownLocale } from '../../types';
import type { EmojiSpaceCleanerUI } from './ui';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as EmojiSpaceCleanerUI;
---

<div
  class="ec-card"
  data-copied={t.toastCopied}
  data-stat-emojis={t.statEmojis}
  data-stat-spaces={t.statSpaces}
  data-stat-none={t.statNone}
>
  <div class="ec-toggles">
    <button class="ec-toggle ec-toggle-active" data-toggle="emojis" aria-pressed="true">
      <span class="ec-toggle-dot"></span>
      {t.labelToggleEmojis}
    </button>
    <button class="ec-toggle ec-toggle-active" data-toggle="spaces" aria-pressed="true">
      <span class="ec-toggle-dot"></span>
      {t.labelToggleSpaces}
    </button>
  </div>

  <div class="ec-panels">
    <div class="ec-panel">
      <div class="ec-panel-header">
        <span class="ec-label">{t.labelInput}</span>
        <button class="ec-btn" data-clear>{t.btnClear}</button>
      </div>
      <textarea
        class="ec-textarea ec-input"
        data-input
        placeholder={t.placeholderInput}
        spellcheck="false"
      ></textarea>
    </div>

    <div class="ec-panel">
      <div class="ec-panel-header">
        <span class="ec-label">{t.labelOutput}</span>
        <button class="ec-btn ec-btn-copy" data-copy>{t.btnCopy}</button>
      </div>
      <textarea
        class="ec-textarea ec-output"
        data-output
        placeholder={t.placeholderOutput}
        readonly
        spellcheck="false"
      ></textarea>
    </div>
  </div>

  <div class="ec-stats" data-stats></div>
  <div class="ec-toast" data-toast></div>
</div>

<script>
  import { cleanText } from './logic';

  function getToggles(card: HTMLElement) {
    return {
      emojis: card.querySelector<HTMLButtonElement>('[data-toggle="emojis"]')?.getAttribute('aria-pressed') === 'true',
      spaces: card.querySelector<HTMLButtonElement>('[data-toggle="spaces"]')?.getAttribute('aria-pressed') === 'true',
    };
  }

  function renderStats(card: HTMLElement, emojis: number, spaces: number) {
    const el = card.querySelector<HTMLElement>('[data-stats]');
    if (!el) return;
    const none = card.dataset.statNone ?? '';
    const se = card.dataset.statEmojis ?? '';
    const ss = card.dataset.statSpaces ?? '';
    el.textContent = emojis === 0 && spaces === 0 ? none : `${emojis} ${se} · ${spaces} ${ss}`;
  }

  function process(card: HTMLElement) {
    const input = card.querySelector<HTMLTextAreaElement>('[data-input]');
    const output = card.querySelector<HTMLTextAreaElement>('[data-output]');
    if (!input || !output) return;
    const { emojis, spaces } = getToggles(card);
    const result = cleanText(input.value, emojis, spaces);
    output.value = result.text;
    renderStats(card, result.emojisRemoved, result.spacesNormalized);
  }

  function showToast(toast: HTMLElement, msg: string) {
    toast.textContent = msg;
    toast.classList.add('ec-toast-visible');
    setTimeout(() => toast.classList.remove('ec-toast-visible'), 1800);
  }

  function attachToggle(card: HTMLElement, btn: HTMLButtonElement) {
    btn.addEventListener('click', () => {
      const active = btn.getAttribute('aria-pressed') === 'true';
      btn.setAttribute('aria-pressed', String(!active));
      btn.classList.toggle('ec-toggle-active', !active);
      process(card);
    });
  }

  function attachCopy(card: HTMLElement) {
    const btn = card.querySelector<HTMLButtonElement>('[data-copy]');
    const toast = card.querySelector<HTMLElement>('[data-toast]');
    const output = card.querySelector<HTMLTextAreaElement>('[data-output]');
    if (!btn || !toast || !output) return;
    btn.addEventListener('click', () => {
      if (!output.value) return;
      navigator.clipboard.writeText(output.value);
      showToast(toast, card.dataset.copied ?? 'Copied!');
    });
  }

  function init() {
    document.querySelectorAll<HTMLElement>('.ec-card').forEach((card) => {
      const input = card.querySelector<HTMLTextAreaElement>('[data-input]');
      const clearBtn = card.querySelector<HTMLButtonElement>('[data-clear]');
      const output = card.querySelector<HTMLTextAreaElement>('[data-output]');
      if (!input || !clearBtn || !output) return;
      input.addEventListener('input', () => process(card));
      clearBtn.addEventListener('click', () => { input.value = ''; output.value = ''; });
      card.querySelectorAll<HTMLButtonElement>('[data-toggle]').forEach((btn) => attachToggle(card, btn));
      attachCopy(card);
    });
  }

  document.addEventListener('astro:page-load', init);
  init();
</script>

<style>
  .ec-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }

  .ec-toggles {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .ec-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.875rem;
    border: 1px solid var(--border-color);
    border-radius: 99px;
    background: var(--bg-page);
    color: var(--text-muted);
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .ec-toggle-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border-color);
    transition: background 0.15s ease;
  }

  .ec-toggle-active {
    color: var(--accent);
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .ec-toggle-active .ec-toggle-dot {
    background: var(--accent);
  }

  .ec-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .ec-panels {
      grid-template-columns: 1fr;
    }
  }

  .ec-panel {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ec-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 2rem;
  }

  .ec-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .ec-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border-color);
    border-radius: 0.4rem;
    background: var(--bg-page);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .ec-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .ec-textarea {
    width: 100%;
    min-height: 280px;
    padding: 0.875rem;
    background: var(--bg-page);
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    color: var(--text-main);
    font-size: 0.875rem;
    line-height: 1.6;
    resize: vertical;
    box-sizing: border-box;
    transition: border-color 0.15s ease;
  }

  .ec-textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  .ec-output {
    color: var(--text-muted);
  }

  .ec-stats {
    font-size: 0.8125rem;
    color: var(--text-muted);
    min-height: 1.2em;
  }

  .ec-toast {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(0.5rem);
    background: var(--text-main);
    color: var(--bg-page);
    padding: 0.5rem 1.25rem;
    border-radius: 99px;
    font-size: 0.8125rem;
    font-weight: 600;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .ec-toast-visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>
